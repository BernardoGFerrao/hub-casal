# ─── Senhas de acesso ao hub ──────────────────────────────────────────────
# Deixe em branco para acesso sem senha (não recomendado em rede compartilhada)
PASSWORD_BERNARDO=suasenha
PASSWORD_AMANDA=suasenha

# Chave secreta para assinar os cookies (use uma string aleatória de 64 chars)
HUB_SECRET_KEY=troque-por-uma-string-aleatoria-de-64-caracteres-aqui-xxxxxxxxxxxxxxxx

# ─── IA ───────────────────────────────────────────────────────────────────
# Obtida em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Notícias ─────────────────────────────────────────────────────────────
# Opcional — sem esta chave usa RSS do Google News gratuitamente
GNEWS_API_KEY=

# ─── Clima (para o briefing diário) ───────────────────────────────────────
# Nome da cidade em inglês ou português (ex: Pelotas, Sao Paulo, Rio de Janeiro)
HUB_CITY=Pelotas

# ─── Finanças (opcional) ──────────────────────────────────────────────────
# Obtidas em https://pluggy.ai (Open Finance Brasil)
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
